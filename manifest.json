{
  "manifest_version": 2,
  "name": "Extensão de Privacidade para Firefox",
  "version": "1.0",
  "description": "Detecção de ameaças à privacidade e rastreamento em cliente web.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage",
    "cookies"
  ],
  "data_collection_permissions": {
    "collection_accepted": false 
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_start"
    }
  ],
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_title": "Ver Relatório de Privacidade"
  }
}